from datetime import datetime

tasks = []

def menu():
    choice = int(input("""Menu

1. Add new task
2. Delete task
3. Search task
4. Modify task
5. End

Enter choice: """))
    return choice


choice = menu()

while choice != 5:

    if choice < 1 or choice > 5:
        print("Invalid input!")

    else:
        if choice == 1:
            taskname = input("Enter task name: ")
            description = input("Enter task description: ")
            duedate = datetime.strptime(input("Enter due date (YYYY-MM-DD): "), "%Y-%m-%d")

            add_task = {'taskname': taskname, 'description': description, 'duedate': duedate}

            tasks.append(add_task)
            print("Task added!")

        elif choice == 2:
            delete = input("Enter task name you want to delete: ")

            found = False
            for task in tasks:
                if task['taskname'] == delete:
                    tasks.remove(task)
                    found = True
                    print("Task deleted!")
                    break

            if not found:
                print("Task not found!")

        elif choice == 3:
            find_taskname = input("Enter task name to search: ")

            found = False
            for task in tasks:
                if task['taskname'] == find_taskname:
                    print(task)
                    print("Task found!")
                    found = True
                    break

            if not found:
                print("Task does not exist!")

        elif choice == 4:
            modify_taskname = input("Enter task name to modify: ")

            found = False
            for task in tasks:
                if task['taskname'] == modify_taskname:
                    new_name = input("Enter new task name: ")
                    new_description = input("Enter new description: ")
                    new_duedate = datetime.strptime(input("Enter new due date (YYYY-MM-DD): "), "%Y-%m-%d")

                    task['taskname'] = new_name
                    task['description'] = new_description
                    task['duedate'] = new_duedate

                    print("Task modified!")
                    found = True
                    break

            if not found:
                print("Task does not exist!")

    choice = menu()

print("Goodbye and thank you!")
